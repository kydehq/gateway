# ENTERPRISE edition, DEV posture (local build). Copy to `.env.enterprise-dev`.
#
# Builds the enterprise gateway image locally instead of the starter default. Requires
# the kyde-enterprise wheel in ./wheels/ (see docs/building-images.md) — the
# build hard-fails without it.
#
#   docker compose --env-file .env.enterprise-dev up --build
#
# The dev override reads ${EDITION} for the build arg and ${GATEWAY_REPO} names
# the local image tag; nothing is pulled from ghcr in this mode.

EDITION=enterprise
GATEWAY_REPO=gateway-distribution
POSTGRES_PASSWORD=kyde-dev-only
