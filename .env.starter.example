# STARTER edition (public core image), any posture. Copy to `.env.starter`.
#
# Hardened public deployment (prod posture + starter image — this is the combo
# that the old split files could not express):
#   docker compose --env-file .env.starter \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# A plain `docker compose up -d` already pulls the published starter images and
# does NOT need this file — use this only for the hardened prod posture on the
# public image (real POSTGRES_PASSWORD, resource limits, restart:always).

REGISTRY=ghcr.io/kydehq
GATEWAY_REPO=gateway                 # public core gateway/ui images (this repo)
DLP_REPO=gateway-distribution        # DLP sidecars ship only from the licensed repo
TAG=latest
DLP_BERT_VERSION=latest
DLP_REGEX_VERSION=latest

POSTGRES_PASSWORD=change-me-before-deploy
HF_USER_ORG=kydehq
