# PROD posture + ENTERPRISE edition. Copy to `.env.prod` and fill real values.
# Never commit `.env.prod`.
#
#   cp .env.prod.example .env.prod
#   docker compose --env-file .env.prod \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Recover a locked-out deployment:
#   docker compose --env-file .env.prod \
#     -f docker-compose.yml -f docker-compose.prod.yml \
#     exec kyde-api kyde admin create-admin --username rescue --email you@co

# ---- Edition + image selection -----------------------------------------

# The edition switch. Enterprise pulls the licensed gateway/ui images.
#   enterprise    → gateway-distribution
#   starter       → gateway     (see .env.starter.example)
REGISTRY=ghcr.io/kydehq
GATEWAY_REPO=gateway-distribution
DLP_REPO=gateway-distribution

# Gateway + UI image tag, published by .github/workflows/release-docker.yml
# (enterprise gateway is published by the gateway-enterprise pipeline).
TAG=v0.3.1

# DLP sidecar image versions.
DLP_BERT_VERSION=v0.2.0
DLP_REGEX_VERSION=v0.2.0

# ---- Required ----------------------------------------------------------

# Password for the Postgres `kyde` user (ledger + users + DLP alerts). It never
# leaves the host unless you expose the DB port (don't).
#   openssl rand -base64 32
POSTGRES_PASSWORD=change-me-before-deploy

# ---- Optional ----------------------------------------------------------

# Hugging Face org/user namespace for the DLP-BERT model (--profile with-bert).
HF_USER_ORG=kydehq
